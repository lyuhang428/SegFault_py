&CONTROL
 prefix = "NaCl",
 pseudo_dir = '../pseudo',
 outdir = "./NaCl"
 /
 
 &SYSTEM
 ibrav = 1,
 A = 10,
 ecutwfc = 50,
 nat = 2,
 ntyp = 2,
 !input_dft = pz
 /
 
